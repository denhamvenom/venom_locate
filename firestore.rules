rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Internal team app — open read/write for now.
    // Tighten before exposing publicly.
    match /events/{eventCode}/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    match /config/{doc} {
      allow read: if true;
      allow write: if true;
    }
  }
}
